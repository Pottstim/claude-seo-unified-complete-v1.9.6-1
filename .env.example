# Claude SEO Unified - Environment Variables
# Copy to .env and fill in the values you need
# Only set keys for providers you actually use

# ============================================================
# LLM PROVIDERS (choose one or more)
# ============================================================

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI GPT / DALL-E
OPENAI_API_KEY=

# Groq (fast inference, free tier)
GROQ_API_KEY=

# Cerebras (ultra-fast)
CEREBRAS_API_KEY=

# OpenRouter (aggregator - access to 100+ models)
OPENROUTER_API_KEY=

# Together AI
TOGETHER_API_KEY=

# Custom LLM endpoint (LM Studio, vLLM, etc.)
LLM_BASE_URL=
LLM_API_KEY=

# ============================================================
# GOOGLE APIs
# ============================================================

# PageSpeed Insights API (free tier available)
GOOGLE_PAGESPEED_API_KEY=

# Chrome UX Report API (real user data)
GOOGLE_CRUX_API_KEY=

# Google AI (Gemini / Imagen)
GOOGLE_AI_API_KEY=

# ============================================================
# SERP / KEYWORD RESEARCH (choose one)
# ============================================================

# SerpAPI (100 free searches/month)
SERPAPI_KEY=

# DataForSEO (pay-per-use)
DATAFORSEO_USERNAME=
DATAFORSEO_PASSWORD=

# ValueSERP
VALUESERP_KEY=

# ScraperAPI (general purpose)
SCRAPERAPI_KEY=

# ============================================================
# WEB CRAWLING
# ============================================================

# Firecrawl (managed JS rendering)
FIRECRAWL_API_KEY=

# Browserless
BROWSERLESS_KEY=
BROWSERLESS_URL=

# ============================================================
# IMAGE GENERATION (choose one)
# ============================================================

# Replicate (hosted SD models)
REPLICATE_API_KEY=

# HuggingFace Inference
HUGGINGFACE_API_KEY=

# Banana.dev
BANANA_API_KEY=

# Stable Diffusion WebUI (self-hosted)
SD_WEBUI_URL=http://localhost:7860

# ComfyUI (self-hosted)
COMFYUI_URL=http://localhost:8188

# ============================================================
# ANALYTICS
# ============================================================

# Plausible (privacy-focused)
PLAUSIBLE_API_KEY=
PLAUSIBLE_SITE_ID=
PLAUSIBLE_URL=

# Matomo (self-hosted)
MATOMO_URL=
MATOMO_SITE_ID=
MATOMO_AUTH_TOKEN=

# Google Analytics 4
GA4_PROPERTY_ID=

# ============================================================
# BACKLINK / COMPETITOR ANALYSIS
# ============================================================

# Ahrefs
AHREFS_API_KEY=

# Moz
MOZ_ACCESS_ID=
MOZ_SECRET_KEY=

# SEMrush
SEMRUSH_API_KEY=

# Majestic
MAJESTIC_API_KEY=

# ============================================================
# MISC
# ============================================================

# Custom proxy list for scraping (comma-separated or file path)
PROXY_LIST=

# Custom analytics endpoint
ANALYTICS_API_URL=
ANALYTICS_API_KEY=
