# Google APIs Extension Environment Variables
# Copy to .env.google in project root

# PageSpeed Insights API
GOOGLE_PAGESPEED_API_KEY=your_pagespeed_api_key_here

# Chrome UX Report API
GOOGLE_CRUX_API_KEY=your_crux_api_key_here

# Google Analytics 4 (optional)
GA4_PROPERTY_ID=your_property_id_here

# OAuth 2.0 (Search Console & Analytics)
# Download credentials.json from Google Cloud Console
# Place in config/credentials/credentials.json
# First run: python scripts/google_auth_setup.py
