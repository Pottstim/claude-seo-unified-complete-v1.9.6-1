# Claude SEO Unified Environment Variables
# Copy to .env in project root and configure

# Core AI Models
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# DataForSEO (optional - for live SERP & backlink data)
DATAFORSEO_USERNAME=your_username
DATAFORSEO_PASSWORD=your_password
DATAFORSEO_API_ENDPOINT=https://api.dataforseo.com/v3

# Google APIs (optional)
GOOGLE_PAGESPEED_API_KEY=AIza...
GOOGLE_CRUX_API_KEY=AIza...
GA4_PROPERTY_ID=123456789

# Firecrawl (optional - for JS-heavy sites)
FIRECRAWL_API_KEY=fc-...
FIRECRAWL_API_ENDPOINT=https://api.firecrawl.dev/v1

# Banana/Gemini Image Generation (optional)
BANANA_API_KEY=...
GEMINI_API_KEY=AIza...

# Notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Email notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com

# Database (optional - for drift monitoring)
DATABASE_URL=postgresql://user:pass@localhost:5432/seo_db

# Security
SECRET_KEY=your_secret_key_here_min_32_chars
ALLOWED_HOSTS=localhost,127.0.0.1

# Debug
DEBUG=false
LOG_LEVEL=INFO
